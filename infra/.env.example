# Production secrets for the podkit cloud control-plane.
# Copy to infra/.env (gitignored) and fill in. Generate the two keys with:
#   openssl rand -hex 32
#
# docker compose -f infra/docker-compose.prod.yml --env-file infra/.env up -d --build

# Postgres superuser password for the control-plane's own database + as the
# admin role used to provision per-project databases. Use a long random value.
POSTGRES_PASSWORD=

# HMAC secret for signing account/CLI bearer tokens (64 hex chars / 32 bytes).
# openssl rand -hex 32
PODKIT_AUTH_SECRET=

# AES-256-GCM key for encrypting secrets at rest (env vars, scoped DB creds).
# Exactly 64 hex chars / 32 bytes. openssl rand -hex 32
PODKIT_SECRETS_KEY=

# Machine API key for full (non-account) control-plane access (CI, admin tools).
# A long random value.
PODKIT_API_KEY=

# Public URL where the console is reached (used in CLI device-flow verify URLs),
# e.g. https://cloud.example.com . Optional but recommended.
PODKIT_CONSOLE_URL=

# Comma-separated allowed browser origins for the API (CORS). Leave empty to
# allow any origin. e.g. https://cloud.example.com
PODKIT_CORS_ORIGINS=

# Host port bindings (optional; default 8080 console/API, 8090 gateway). Bind to
# 127.0.0.1 when fronting with a reverse proxy, e.g. PODKIT_API_BIND=127.0.0.1:8080
PODKIT_API_BIND=8080
PODKIT_GATEWAY_BIND=8090

# Abuse caps (recommended for a public/untrusted deployment).
# Max projects a single account may own (unset/0 = unlimited).
PODKIT_MAX_PROJECTS_PER_ACCOUNT=25
# Max API requests per minute, per credential or IP (unset = 600; <=0 disables).
PODKIT_RATE_LIMIT_PER_MIN=600
